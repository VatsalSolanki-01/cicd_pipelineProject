pipeline {
    agent any

    stages {

        stage('Clone Repository') {
            steps {
                git branch: 'main',
                url: 'https://github.com/VatsalSolanki-01/cicd_pipelineProject.git'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t go-cicd-app .'
            }
        }

    }
}